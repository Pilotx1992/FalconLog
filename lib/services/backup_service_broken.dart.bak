  // Restore from Google Drive
  static Future<RestoreResult> restoreFromGoogleDrive({String? backupId}) async {
    try {
      // TODO: Google Drive restore temporarily disabled due to API compatibility issues
      return RestoreResult.error('Google Drive restore is currently under maintenance. Please use local restore instead.');
      
      /* Original implementation commented out
      final googleSignIn = GoogleSignIn(scopes: ['https://www.googleapis.com/auth/drive.file']);
      
      // Sign in to Google account
      final GoogleSignInAccount? account = await googleSignIn.signIn();
      if (account == null) {
        return RestoreResult.error('Google sign-in cancelled or unavailable');
      }
      
      // Get authentication headers
      final GoogleSignInAuthentication authentication = await account.authentication;
      final authHeaders = {
        'Authorization': 'Bearer ${authentication.accessToken}',
        'Content-Type': 'application/json',
      };
      
      // Create authenticated HTTP client
      final client = GoogleAuthClient(authHeaders);
      final driveApi = drive.DriveApi(client);
      
      // List backup files in FalconLog Backups folder (visible files)
      final folderName = 'FalconLog Backups';
      
      // First, find the FalconLog Backups folder
      final folderSearch = await driveApi.files.list(
        q: "mimeType='application/vnd.google-apps.folder' and name='$folderName' and trashed=false",
        spaces: 'drive',
      );
      
      String? folderId;
      if (folderSearch.files != null && folderSearch.files!.isNotEmpty) {
        folderId = folderSearch.files!.first.id;
      }
      
      if (folderId == null) {
        client.close();
        return RestoreResult.error('No FalconLog Backups folder found on Google Drive');
      }
      
      // List backup files in the folder
      final fileList = await driveApi.files.list(
        q: "'$folderId' in parents and name contains 'falconlog_backup_' and trashed=false",
        orderBy: 'createdTime desc',
      );
      
      if (fileList.files == null || fileList.files!.isEmpty) {
        client.close();
        return RestoreResult.error('No backups found on Google Drive');
      }
      
      // Get the most recent backup or specific backup
      drive.File? targetFile;
      if (backupId != null) {
        targetFile = fileList.files!.firstWhere(
          (file) => file.id == backupId,
          orElse: () => fileList.files!.first,
        );
      } else {
        targetFile = fileList.files!.first;
      }
      
      // Download file
      final response = await driveApi.files.get(
        targetFile.id!,
        downloadOptions: drive.DownloadOptions.fullMedia,
      );
      
      if (response is drive.Media) {
        // Read the file data
        final List<int> dataBytes = [];
        await for (final chunk in response.stream) {
          dataBytes.addAll(chunk);
        }
        
        // Convert bytes to string
        final encryptedData = utf8.decode(dataBytes);
        
        // Decrypt data
        final backupContent = await _decryptBackupData(encryptedData);
        
        client.close();
        
        if (backupContent['logs'] != null) {
          final logs = (backupContent['logs'] as List)
              .map((logJson) => FlightLog.fromJson(logJson as Map<String, dynamic>))
              .toList();
          
          return RestoreResult.success(
            logs: logs,
            timestamp: DateTime.parse(backupContent['timestamp']),
            version: backupContent['version'],
            deviceInfo: backupContent['device_info'],
          );
        } else {
          return RestoreResult.error('Invalid backup file format');
        }
      } else {
        client.close();
        return RestoreResult.error('Failed to download backup from Google Drive');
      }
    } catch (e) {
      print('Google Drive restore error: $e');
      return RestoreResult.error('Google Drive restore failed: $e');
    }
  }

  static Future<RestoreResult> restoreFromLocal(String filePath) async {
    try {
      final file = File(filePath);
      if (!await file.exists()) {
        return RestoreResult.error('Backup file not found');
      }
      
      final encryptedData = await file.readAsString();
      final decryptedData = await _decryptBackupData(encryptedData);
      
      final logs = (decryptedData['logs'] as List)
          .map((logData) => FlightLog.fromJson(logData))
          .toList();
      
      return RestoreResult.success(
        logs: logs,
        timestamp: DateTime.parse(decryptedData['timestamp']),
        version: decryptedData['version'],
        deviceInfo: decryptedData['device_info'],
      );
    } catch (e) {
      print('Local restore error: $e');
      return RestoreResult.error('Local restore failed: $e');
    }
  }
  
  // Get backup history from Firebase
  static Future<List<BackupInfo>> getBackupHistory() async {
    try {
      final user = FirebaseAuth.instance.currentUser;
      if (user == null) return [];
      
      final firestore = FirebaseFirestore.instance;
      final query = await firestore
          .collection('user_backups')
          .doc(user.uid)
          .collection('backups')
          .orderBy('timestamp', descending: true)
          .limit(20)
          .get();
      
      return query.docs.map((doc) {
        final data = doc.data();
        return BackupInfo(
          id: doc.id,
          timestamp: data['timestamp'] != null 
              ? (data['timestamp'] as Timestamp).toDate()
              : DateTime.now(),
          provider: BackupProvider.firebase,
          logsCount: data['logs_count'] ?? 0,
          backupSize: data['backup_size'] ?? 0,
          deviceId: data['device_id'] ?? 'Unknown',
          checksum: data['checksum'] ?? '',
        );
      }).toList();
    } catch (e) {
      print('Error getting backup history: $e');
      // Check if it's a Firebase API not enabled error
      if (e.toString().contains('PERMISSION_DENIED') || 
          e.toString().contains('firestore.googleapis.com')) {
        print('Firebase Firestore API not enabled. Using local backups only.');
      }
      return [];
    }
  }
  
  // Get local backup files
  static Future<List<BackupInfo>> getLocalBackups() async {
    try {
      final directory = await getApplicationDocumentsDirectory();
      final backupDir = Directory('${directory.path}/backups');
      
      if (!await backupDir.exists()) return [];
      
      final files = await backupDir
          .list()
          .where((entity) => entity is File && entity.path.endsWith('.json'))
          .cast<File>()
          .toList();
      
      final backupInfos = <BackupInfo>[];
      
      for (final file in files) {
        try {
          final stat = await file.stat();
          final fileName = file.path.split('/').last;
          final timestampStr = fileName
              .replaceAll('falcon_backup_', '')
              .replaceAll('.json', '');
          
          if (int.tryParse(timestampStr) != null) {
            final timestamp = DateTime.fromMillisecondsSinceEpoch(
              int.parse(timestampStr)
            );
            
            backupInfos.add(BackupInfo(
              id: file.path,
              timestamp: timestamp,
              provider: BackupProvider.local,
              logsCount: 0, // Will be determined when opening
              backupSize: stat.size,
              deviceId: await _getDeviceId(),
              checksum: '',
            ));
          }
        } catch (e) {
          print('Error processing local backup file: $e');
        }
      }
      
      backupInfos.sort((a, b) => b.timestamp.compareTo(a.timestamp));
      return backupInfos;
    } catch (e) {
      print('Error getting local backups: $e');
      return [];
    }
  }
  
  // Auto backup when new flight is added
  static Future<BackupResult> performAutoBackup(List<FlightLog> logs) async {
    if (!await isAutoBackupEnabled()) {
      return BackupResult.skipped('Auto backup is disabled');
    }
    
    final provider = await getBackupProvider();
    switch (provider) {
      case BackupProvider.firebase:
        return await backupToFirebase(logs);
      case BackupProvider.local:
        return await backupToLocal(logs);
      case BackupProvider.googleDrive:
        return await backupToGoogleDrive(logs);
    }
  }
  
  // Settings management
  static Future<void> setBackupProvider(BackupProvider provider) async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setString(_backupProviderKey, provider.name);
  }
  
  static Future<BackupProvider> getBackupProvider() async {
    final prefs = await SharedPreferences.getInstance();
    final providerName = prefs.getString(_backupProviderKey) ?? 'firebase';
    return BackupProvider.values.firstWhere(
      (p) => p.name == providerName,
      orElse: () => BackupProvider.firebase,
    );
  }
  
  static Future<void> setAutoBackupEnabled(bool enabled) async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setBool(_autoBackupKey, enabled);
  }
  
  static Future<bool> isAutoBackupEnabled() async {
    final prefs = await SharedPreferences.getInstance();
    return prefs.getBool(_autoBackupKey) ?? true;
  }
  
  static Future<DateTime?> getLastBackupTime() async {
    final prefs = await SharedPreferences.getInstance();
    final timestamp = prefs.getInt(_lastBackupKey);
    return timestamp != null 
        ? DateTime.fromMillisecondsSinceEpoch(timestamp) 
        : null;
  }

  // Auto backup configuration management
  static const String _autoBackupConfigKey = 'auto_backup_config';
  
  static Future<void> setAutoBackupConfig(dynamic config) async {
    final prefs = await SharedPreferences.getInstance();
    final configJson = config.toJson();
    await prefs.setString(_autoBackupConfigKey, jsonEncode(configJson));
  }
  
  static Future<dynamic> getAutoBackupConfig() async {
    final prefs = await SharedPreferences.getInstance();
    final configString = prefs.getString(_autoBackupConfigKey);
    
    if (configString != null) {
      try {
        final configJson = jsonDecode(configString);
        // Import will be handled by the provider that knows the AutoBackupConfig class
        return configJson;
      } catch (e) {
        print('Error parsing auto backup config: $e');
      }
    }
    
    // Return default config as JSON
    return {
      'enabled': true,
      'interval': 'weekly',
      'trigger': 'combined',
      'requiresWifi': false,
      'maxBackups': 10,
      'preferredProvider': 'firebase',
      'lastAutoBackup': null,
    };
  }
  
  // Helper methods
  static Future<Map<String, dynamic>> _getDeviceInfo() async {
    return {
      'platform': Platform.operatingSystem,
      'version': Platform.operatingSystemVersion,
      'app_version': '2.0.0',
    };
  }
  
  static Future<String> _getDeviceId() async {
    final prefs = await SharedPreferences.getInstance();
    String? deviceId = prefs.getString('device_id');
    
    if (deviceId == null) {
      deviceId = DateTime.now().millisecondsSinceEpoch.toString();
      await prefs.setString('device_id', deviceId);
    }
    
    return deviceId;
  }
  
  static Future<void> _updateLastBackupTime() async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setInt(_lastBackupKey, DateTime.now().millisecondsSinceEpoch);
  }
  
  static Future<String> _encryptBackupData(Map<String, dynamic> data) async {
    final key = Key.fromBase64(_encryptionKey.padRight(32, '0').substring(0, 32));
    final iv = IV.fromSecureRandom(16);
    final encrypter = Encrypter(AES(key));
    
    final jsonString = jsonEncode(data);
    final encrypted = encrypter.encrypt(jsonString, iv: iv);
    
    return '${iv.base64}:${encrypted.base64}';
  }
  
  static Future<Map<String, dynamic>> _decryptBackupData(String encryptedData) async {
    final parts = encryptedData.split(':');
    if (parts.length != 2) {
      throw Exception('Invalid encrypted data format');
    }
    
    final key = Key.fromBase64(_encryptionKey.padRight(32, '0').substring(0, 32));
    final iv = IV.fromBase64(parts[0]);
    final encrypter = Encrypter(AES(key));
    
    final encrypted = Encrypted.fromBase64(parts[1]);
    final decrypted = encrypter.decrypt(encrypted, iv: iv);
    
    return jsonDecode(decrypted);
  }
  
  static String _generateChecksum(String data) {
    // Simple checksum using hash code
    return data.hashCode.toString();
  }
  
  static Future<void> _cleanOldLocalBackups(Directory backupDir) async {
    try {
      final files = await backupDir
          .list()
          .where((entity) => entity is File && entity.path.endsWith('.json'))
          .cast<File>()
          .toList();
      
      if (files.length > 5) {
        // Sort by modification time and keep only the 5 most recent
        files.sort((a, b) => b.lastModifiedSync().compareTo(a.lastModifiedSync()));
        
        for (int i = 5; i < files.length; i++) {
          await files[i].delete();
        }
      }
    } catch (e) {
      print('Error cleaning old backups: $e');
    }
  }
  
  // Delete specific backup
  static Future<bool> deleteBackup(BackupInfo backup) async {
    try {
      if (backup.provider == BackupProvider.firebase) {
        final user = FirebaseAuth.instance.currentUser;
        if (user == null) return false;
        
        await FirebaseFirestore.instance
            .collection('user_backups')
            .doc(user.uid)
            .collection('backups')
            .doc(backup.id)
            .delete();
      } else {
        final file = File(backup.id);
        if (await file.exists()) {
          await file.delete();
        }
      }
      return true;
    } catch (e) {
      print('Error deleting backup: $e');
      return false;
    }
  }
}

// Result classes
class BackupResult {
  final bool success;
  final String message;
  final int? logsCount;
  final int? backupSize;
  final String? filePath;
  
  BackupResult._({
    required this.success,
    required this.message,
    this.logsCount,
    this.backupSize,
    this.filePath,
  });
  
  factory BackupResult.success({
    required String message,
    int? logsCount,
    int? backupSize,
    String? filePath,
  }) => BackupResult._(
    success: true,
    message: message,
    logsCount: logsCount,
    backupSize: backupSize,
    filePath: filePath,
  );
  
  factory BackupResult.error(String message) => BackupResult._(
    success: false,
    message: message,
  );
  
  factory BackupResult.skipped(String message) => BackupResult._(
    success: false,
    message: message,
  );
}

class RestoreResult {
  final bool success;
  final String? message;
  final List<FlightLog>? logs;
  final DateTime? timestamp;
  final String? version;
  final Map<String, dynamic>? deviceInfo;
  
  RestoreResult._({
    required this.success,
    this.message,
    this.logs,
    this.timestamp,
    this.version,
    this.deviceInfo,
  });
  
  factory RestoreResult.success({
    required List<FlightLog> logs,
    DateTime? timestamp,
    String? version,
    Map<String, dynamic>? deviceInfo,
  }) => RestoreResult._(
    success: true,
    logs: logs,
    timestamp: timestamp,
    version: version,
    deviceInfo: deviceInfo,
  );
  
  factory RestoreResult.error(String message) => RestoreResult._(
    success: false,
    message: message,
  );
}

class BackupInfo {
  final String id;
  final DateTime timestamp;
  final BackupProvider provider;
  final int logsCount;
  final int backupSize;
  final String deviceId;
  final String checksum;
  
  BackupInfo({
    required this.id,
    required this.timestamp,
    required this.provider,
    required this.logsCount,
    required this.backupSize,
    required this.deviceId,
    required this.checksum,
  });
  
  String get formattedSize {
    if (backupSize < 1024) return '${backupSize}B';
    if (backupSize < 1024 * 1024) return '${(backupSize / 1024).toStringAsFixed(1)}KB';
    return '${(backupSize / (1024 * 1024)).toStringAsFixed(1)}MB';
  }
  
  String get formattedDate {
    final now = DateTime.now();
    final difference = now.difference(timestamp);
    
    if (difference.inDays > 7) {
      return '${timestamp.day}/${timestamp.month}/${timestamp.year}';
    } else if (difference.inDays > 0) {
      return '${difference.inDays} day${difference.inDays > 1 ? 's' : ''} ago';
    } else if (difference.inHours > 0) {
      return '${difference.inHours} hour${difference.inHours > 1 ? 's' : ''} ago';
    } else if (difference.inMinutes > 0) {
      return '${difference.inMinutes} minute${difference.inMinutes > 1 ? 's' : ''} ago';
    } else {
      return 'Just now';
    }
  }
  
  String get providerName {
    switch (provider) {
      case BackupProvider.firebase:
        return 'Firebase';
      case BackupProvider.local:
        return 'Local';
      case BackupProvider.googleDrive:
        return 'Google Drive';
    }
  }
}
