import 'package:http/http.dart' as http;
import '../models/flight_log.dart';

enum BackupProvider { firebase, local, googleDrive }

// Custom HTTP client for Google API authentication
class GoogleAuthClient extends http.BaseClient {
  final Map<String, String> _headers;
  final http.Client _client = http.Client();

  GoogleAuthClient(this._headers);

  @override
  Future<http.StreamedResponse> send(http.BaseRequest request) {
    request.headers.addAll(_headers);
    return _client.send(request);
  }

  @override
  void close() {
    _client.close();
  }
}

class BackupService {
  static const String _backupProviderKey = 'backup_provider';
  static const String _autoBackupKey = 'auto_backup_enabled';
  static const String _lastBackupKey = 'last_backup_timestamp';
  static const String _encryptionKey = 'falcon_log_encryption_key_2025';
  
  // Firebase backup with encryption
  static Future<BackupResult> backupToFirebase(List<FlightLog> logs) async {
    try {
      final user = FirebaseAuth.instance.currentUser;
      if (user == null) {
        return BackupResult.error('User not authenticated');
      }
      
      final firestore = FirebaseFirestore.instance;
      
      // Encrypt sensitive data
      final encryptedData = await _encryptBackupData({
        'logs': logs.map((log) => log.toJson()).toList(),
        'timestamp': DateTime.now().toIso8601String(),
        'version': '2.0.0',
        'device_info': await _getDeviceInfo(),
        'total_logs': logs.length,
      });
      
      final backupDoc = {
        'encrypted_data': encryptedData,
        'timestamp': FieldValue.serverTimestamp(),
        'device_id': await _getDeviceId(),
        'backup_size': encryptedData.length,
        'logs_count': logs.length,
        'checksum': _generateChecksum(encryptedData),
      };
      
      // Save as latest backup
      await firestore
          .collection('user_backups')
          .doc(user.uid)
          .collection('backups')
          .doc('latest')
          .set(backupDoc);
      
      // Also create a timestamped backup
      final timestampedDoc = DateTime.now().millisecondsSinceEpoch.toString();
      await firestore
          .collection('user_backups')
          .doc(user.uid)
          .collection('backups')
          .doc(timestampedDoc)
          .set(backupDoc);
      
      await _updateLastBackupTime();
      
      return BackupResult.success(
        message: 'Firebase backup completed successfully',
        logsCount: logs.length,
        backupSize: encryptedData.length,
      );
    } catch (e) {
      print('Firebase backup error: $e');
      return BackupResult.error('Firebase backup failed: $e');
    }
  }
  
  // Local backup with compression
  static Future<BackupResult> backupToLocal(List<FlightLog> logs) async {
    try {
      final directory = await getApplicationDocumentsDirectory();
      final backupDir = Directory('${directory.path}/backups');
      
      if (!await backupDir.exists()) {
        await backupDir.create(recursive: true);
      }
      
      final timestamp = DateTime.now().millisecondsSinceEpoch;
      final backupFile = File('${backupDir.path}/falcon_backup_$timestamp.json');
      
      final backupData = {
        'logs': logs.map((log) => log.toJson()).toList(),
        'timestamp': DateTime.now().toIso8601String(),
        'version': '2.0.0',
        'device_info': await _getDeviceInfo(),
        'total_logs': logs.length,
      };
      
      // Compress and encrypt data
      final encryptedData = await _encryptBackupData(backupData);
      
      await backupFile.writeAsString(encryptedData);
      
      // Clean old backups (keep only last 5)
      await _cleanOldLocalBackups(backupDir);
      
      await _updateLastBackupTime();
      
      return BackupResult.success(
        message: 'Local backup completed successfully',
        logsCount: logs.length,
        backupSize: encryptedData.length,
        filePath: backupFile.path,
      );
    } catch (e) {
      print('Local backup error: $e');
      return BackupResult.error('Local backup failed: $e');
    }
  }
  
  // Restore from Firebase
  static Future<RestoreResult> restoreFromFirebase({String? backupId}) async {
    try {
      final user = FirebaseAuth.instance.currentUser;
      if (user == null) {
        return RestoreResult.error('User not authenticated');
      }
      
      final firestore = FirebaseFirestore.instance;
      final docId = backupId ?? 'latest';
      
      final doc = await firestore
          .collection('user_backups')
          .doc(user.uid)
          .collection('backups')
          .doc(docId)
          .get();
      
      if (!doc.exists) {
        return RestoreResult.error('Backup not found');
      }
      
      final data = doc.data()!;
      final encryptedData = data['encrypted_data'] as String;
      final checksum = data['checksum'] as String;
      
      // Verify checksum
      if (_generateChecksum(encryptedData) != checksum) {
        return RestoreResult.error('Backup data integrity check failed');
      }
      
      // Decrypt data
      final decryptedData = await _decryptBackupData(encryptedData);
      final logs = (decryptedData['logs'] as List)
          .map((logData) => FlightLog.fromJson(logData))
          .toList();
      
      return RestoreResult.success(
        logs: logs,
        timestamp: DateTime.parse(decryptedData['timestamp']),
        version: decryptedData['version'],
        deviceInfo: decryptedData['device_info'],
      );
    } catch (e) {
      print('Firebase restore error: $e');
      return RestoreResult.error('Firebase restore failed: $e');
    }
  }
  
